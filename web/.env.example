# =============================================================================
# SafeScoring Web - Environment Variables Template
# =============================================================================
# IMPORTANT: Copy this file to .env.local and fill in the values
# NEVER commit .env or .env.local files with real values to git!
#
# Generate secrets with: openssl rand -base64 32
# Generate hex keys with: openssl rand -hex 32
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# =============================================================================


# =============================================================================
# SUPABASE - Primary Database (Required)
# Get from: https://supabase.com > Dashboard > Settings > API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# WARNING: Never expose this key client-side!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# SUPABASE - Reference Database (Optional, for multi-storage)
# A second Supabase project for reference data (products, norms)
# =============================================================================
# SUPABASE_REF_URL=https://your-second-project.supabase.co
# SUPABASE_REF_SERVICE_KEY=your-ref-service-role-key


# =============================================================================
# NEXTAUTH - Authentication (Required)
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
# Trust the host header (set to your domain in production)
# AUTH_TRUST_HOST=https://safescoring.io


# =============================================================================
# GOOGLE OAUTH (Optional - for Google sign-in)
# Get from: https://console.cloud.google.com/apis/credentials
# =============================================================================
# GOOGLE_ID=your-google-client-id
# GOOGLE_SECRET=your-google-client-secret


# =============================================================================
# AI PROVIDERS - Chat & Evaluations
# Priority chain: Groq -> Cerebras -> OpenRouter -> DeepSeek -> Mistral -> Ollama
# =============================================================================

# Groq (FREE - 100k tokens/day per key)
# Get keys at: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key

# OpenRouter (30+ free models, $5 initial credits)
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key

# Cerebras (FREE tier - fast inference)
# Get key at: https://cloud.cerebras.ai
# CEREBRAS_API_KEY=your-cerebras-api-key

# DeepSeek (excellent quality - $0.14/1M tokens)
# Get key at: https://platform.deepseek.com
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Mistral AI (FREE - 1 billion tokens/month)
# Get key at: https://console.mistral.ai
# MISTRAL_API_KEY=your-mistral-api-key

# OpenAI (used by libs/gpt.js)
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key

# Google Gemini (primary AI - multi-key rotation)
# Get keys at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-gemini-api-key

# Tavily (web search for AI chat)
# Get key at: https://tavily.com
# TAVILY_API_KEY=your-tavily-api-key

# Local AI via Ollama (no API key needed)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL_FAST=llama3.2:latest


# =============================================================================
# LEMON SQUEEZY - Fiat Payments (Credit Card)
# Get from: https://app.lemonsqueezy.com/settings/api
# =============================================================================
# LEMON_SQUEEZY_API_KEY=your-api-key
# LEMON_SQUEEZY_STORE_ID=your-store-id
# LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# Plan variant IDs (from LemonSqueezy product dashboard)
# LEMON_SQUEEZY_EXPLORER_VARIANT_ID=
# LEMON_SQUEEZY_PRO_VARIANT_ID=
# LEMON_SQUEEZY_ENTERPRISE_VARIANT_ID=

# Verified Badge variant IDs
# LEMON_SQUEEZY_BADGE_MONTHLY_VARIANT_ID=
# LEMON_SQUEEZY_BADGE_YEARLY_VARIANT_ID=

# Audit upgrade variant IDs (client-side)
# NEXT_PUBLIC_LS_AUDIT_BASIC_VARIANT_ID=
# NEXT_PUBLIC_LS_AUDIT_FULL_VARIANT_ID=

# Add-on variant IDs
# LEMON_SQUEEZY_ADDON_API_BOOST_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_WHITE_LABEL_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_CUSTOM_SCORING_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_SUPPORT_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_EXTRA_SETUPS_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_TEAM_SEATS_VARIANT_ID=
# LEMON_SQUEEZY_ADDON_PRIORITY_ALERTS_VARIANT_ID=

# Certification plan variant IDs
# LEMON_CERT_STARTER_MONTHLY=
# LEMON_CERT_STARTER_YEARLY=
# LEMON_CERT_VERIFIED_MONTHLY=
# LEMON_CERT_VERIFIED_YEARLY=
# LEMON_CERT_ENTERPRISE_MONTHLY=
# LEMON_CERT_ENTERPRISE_YEARLY=


# =============================================================================
# STRIPE - Alternative Fiat Payments (Optional)
# Get from: https://dashboard.stripe.com/apikeys
# =============================================================================
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# =============================================================================
# MOONPAY - Crypto-to-Fiat Payments
# Get from: https://dashboard.moonpay.com
# =============================================================================
# MOONPAY_SECRET_KEY=your-moonpay-secret-key
# MOONPAY_PUBLISHABLE_KEY=your-moonpay-publishable-key
# MOONPAY_WEBHOOK_SECRET=your-moonpay-webhook-secret
# MOONPAY_RECEIVER_WALLET_ADDRESS=0x...
# Client-side publishable key
# NEXT_PUBLIC_MOONPAY_PUBLISHABLE_KEY=your-moonpay-publishable-key


# =============================================================================
# NOWPAYMENTS - Direct Crypto Payments (BTC/ETH/USDC)
# Get from: https://nowpayments.io
# =============================================================================
# NOWPAYMENTS_API_KEY=your-nowpayments-api-key
# NOWPAYMENTS_IPN_SECRET=your-ipn-webhook-secret


# =============================================================================
# WEB3 / BLOCKCHAIN - WalletConnect & Polygon
# =============================================================================

# WalletConnect project ID (required for wallet connections)
# Get from: https://cloud.walletconnect.com
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Polygon RPC URL for on-chain reads/writes
# POLYGON_RPC_URL=https://polygon-rpc.com

# Smart contract addresses (mainnet)
# NEXT_PUBLIC_SAFEPASS_NFT_ADDRESS=0x...
# NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS=0x...
# REGISTRY_ADDRESS_MAINNET=0x...
# REGISTRY_ADDRESS_POLYGON=0x...

# Smart contract addresses (testnet)
# NEXT_PUBLIC_SAFEPASS_NFT_ADDRESS_TESTNET=0x...
# NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS_TESTNET=0x...

# Superfluid streaming payments - treasury address
# NEXT_PUBLIC_SUPERFLUID_TREASURY=0x...
# NEXT_PUBLIC_TREASURY_ADDRESS=0x...

# Private key for publishing proofs on-chain (server-side only!)
# PUBLISHER_PRIVATE_KEY=your-private-key-hex
# Agent economy private key
# AGENT_PRIVATE_KEY=your-agent-private-key

# Block explorer API keys (for gas estimation & wallet verification)
# ETHERSCAN_API_KEY=your-etherscan-api-key
# POLYGONSCAN_API_KEY=your-polygonscan-api-key
# BSCSCAN_API_KEY=your-bscscan-api-key
# ARBISCAN_API_KEY=your-arbiscan-api-key
# OPTIMISM_API_KEY=your-optimism-api-key
# SNOWTRACE_API_KEY=your-avalanche-snowtrace-api-key


# =============================================================================
# EMAIL - Resend
# Get from: https://resend.com/api-keys
# =============================================================================
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=SafeScoring <noreply@safescoring.io>


# =============================================================================
# ANALYTICS & ERROR TRACKING - Sentry
# Get from: https://sentry.io/settings/projects/
# =============================================================================
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token


# =============================================================================
# PUSH NOTIFICATIONS - Web Push / VAPID
# Generate with: npx web-push generate-vapid-keys
# =============================================================================
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key


# =============================================================================
# SOCIAL - Telegram
# =============================================================================
# Bot token from @BotFather
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Chat ID for admin notifications (anti-copy alerts)
# TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
# Chat ID for security alerts
# TELEGRAM_SECURITY_CHAT_ID=your-security-chat-id


# =============================================================================
# SOCIAL - Discord & Slack (Webhooks)
# =============================================================================
# Discord webhook for audit/contact form notifications
# DISCORD_AUDIT_WEBHOOK=https://discord.com/api/webhooks/xxx/xxx
# Slack webhook for audit/contact form notifications
# SLACK_AUDIT_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx
# Slack webhook for security alerts
# SLACK_SECURITY_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx


# =============================================================================
# SOCIAL - Twitter/X (used by marketing automation workflows)
# =============================================================================
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret
# TWITTER_ACCESS_TOKEN=your-twitter-access-token
# TWITTER_ACCESS_SECRET=your-twitter-access-secret
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token


# =============================================================================
# SOCIAL - Reddit (used by marketing automation workflows)
# =============================================================================
# REDDIT_CLIENT_ID=your-reddit-client-id
# REDDIT_CLIENT_SECRET=your-reddit-client-secret
# REDDIT_USERNAME=your-reddit-username
# REDDIT_PASSWORD=your-reddit-password


# =============================================================================
# CLOUDFLARE TURNSTILE - Bot Protection / CAPTCHA
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# =============================================================================
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key


# =============================================================================
# CRON JOBS - Secret for authenticating cron endpoints
# =============================================================================
# Generate with: openssl rand -base64 32
# CRON_SECRET=your-cron-secret


# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
# Comma-separated list of admin email addresses (first = super admin)
# ADMIN_EMAILS=admin@safescoring.io,support@safescoring.io
# Fallback admin email for notifications
# ADMIN_EMAIL=admin@safescoring.io


# =============================================================================
# SECURITY - Encryption & Hashing
# =============================================================================
# AES encryption key for sensitive data (generate: openssl rand -hex 32)
# ENCRYPTION_KEY=your-64-character-hex-encryption-key

# CSRF protection secret (generate: openssl rand -base64 32)
# CSRF_SECRET=your-csrf-secret

# Salt for hashing wallet addresses (generate: openssl rand -hex 32)
# WALLET_HASH_SALT=your-wallet-hash-salt-64-chars-hex

# Salt for hashing email addresses (generate: openssl rand -hex 32)
# EMAIL_HASH_SALT=your-email-hash-salt-64-chars-hex

# Salt for hashing voter identities
# VOTER_HASH_SALT=your-voter-hash-salt

# Salt for privacy utilities
# PRIVACY_HASH_SALT=your-privacy-hash-salt

# Secret for honeypot product fingerprinting
# HONEYPOT_SECRET=your-honeypot-secret

# Secret for steganographic content fingerprinting
# FINGERPRINT_SECRET=your-fingerprint-secret


# =============================================================================
# SECURITY - Anti-Scraping Configuration
# =============================================================================
# Probability of injecting honeypot products (0.0 to 1.0)
# HONEYPOT_INJECTION_RATE=0.7
# Maximum honeypot products per page
# MAX_HONEYPOTS=4
# Enable fingerprint tracking (set to "false" to disable)
# ENABLE_FINGERPRINT_TRACKING=true
# Threshold for scraper detection (number of requests)
# SCRAPER_THRESHOLD=100


# =============================================================================
# RATE LIMITING
# =============================================================================
# Redis URL for production rate limiting
# REDIS_URL=redis://localhost:6379

# Upstash Redis (serverless, recommended for Vercel)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Rate limits (requests per minute) - defaults shown
# RATE_LIMIT_PUBLIC=30
# RATE_LIMIT_AUTHENTICATED=200
# RATE_LIMIT_ADMIN=100


# =============================================================================
# TURSO - Historical Data Storage (Optional)
# Sign up at: https://turso.tech (9GB free tier)
# =============================================================================
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token


# =============================================================================
# PDF REPORT SERVICE (Optional)
# =============================================================================
# URL of the PDF generation service
# PDF_SERVICE_URL=https://your-pdf-service.com
# API key for the PDF service
# PDF_SERVICE_KEY=your-pdf-service-key


# =============================================================================
# CORS & DOMAIN CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins for CORS
# ALLOWED_ORIGINS=http://localhost:3000,https://safescoring.io,https://www.safescoring.io

# Public-facing domain and URLs
# NEXT_PUBLIC_DOMAIN=safescoring.io
# NEXT_PUBLIC_URL=https://safescoring.io
# NEXT_PUBLIC_SITE_URL=https://safescoring.io
# NEXT_PUBLIC_APP_URL=https://safescoring.io
# SITE_URL=https://safescoring.io


# =============================================================================
# VERCEL (Auto-set by Vercel, do not set manually)
# =============================================================================
# VERCEL_URL is auto-set by Vercel deployments
# CI is auto-set in CI environments
# NEXT_PHASE is set during build phases
# NEXT_RUNTIME is set at runtime (nodejs or edge)
# NODE_ENV is set automatically (development/production/test)


# =============================================================================
# TESTING
# =============================================================================
# Base URL for integration tests
# TEST_BASE_URL=http://localhost:3000
