# =============================================================================
# SafeScoring Environment Variables Template
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in the values
# NEVER commit .env files with real values to git!
#
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth Configuration
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
AUTH_TRUST_HOST=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# IMPORTANT: Get this from Supabase Dashboard > Settings > API > service_role key
# This is required for server-side operations (creating users, etc.)
# WARNING: Never expose this key client-side!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Google OAuth (optional)
# Get from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_ID=
GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Resend (for emails)
# Get from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Admin Configuration (RBAC)
# -----------------------------------------------------------------------------
# Comma-separated list of admin emails
ADMIN_EMAILS=admin@safescoring.io

# -----------------------------------------------------------------------------
# Redis (for rate limiting in production)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://safescoring.io

# Rate limiting (requests per minute)
RATE_LIMIT_PUBLIC=30
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_ADMIN=100

# -----------------------------------------------------------------------------
# Lemon Squeezy Payments (primary payment provider)
# Get from: https://app.lemonsqueezy.com/settings/api
# -----------------------------------------------------------------------------
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
# Variant IDs from your Lemon Squeezy product dashboard
# Also set these in config.js under lemonsqueezy.plans[].variantId
LEMON_SQUEEZY_EXPLORER_VARIANT_ID=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_ENTERPRISE_VARIANT_ID=

# -----------------------------------------------------------------------------
# MoonPay (crypto payments)
# Get from: https://dashboard.moonpay.com/
# -----------------------------------------------------------------------------
# Public key (used client-side in checkout URL generation)
NEXT_PUBLIC_MOONPAY_API_KEY=
# Wallet address to receive crypto payments (USDC on Polygon recommended)
MOONPAY_WALLET_ADDRESS=
# Webhook secret for payment verification
MOONPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional)
# Get from: https://sentry.io/settings/projects/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Analytics — Plausible (optional, privacy-first, RGPD compliant)
# Get from: https://plausible.io or self-host
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=safescoring.io
# Custom script URL if self-hosting (default: https://plausible.io/js/script.js)
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.yourdomain.com/js/script.js

# -----------------------------------------------------------------------------
# Cron Jobs (email sequences, etc.)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=
