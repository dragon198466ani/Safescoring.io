{
  "name": "@safescoring/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for SafeScoring - crypto security scores for AI agents",
  "main": "index.js",
  "bin": {
    "safescoring-mcp": "./index.js"
  },
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.mjs 2>/dev/null || echo 'No tests yet'",
