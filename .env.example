# ============================================================
# SafeScoring Environment Variables
# ============================================================

# ============================================================
# SITE CONFIGURATION
# ============================================================
NEXT_PUBLIC_SITE_URL=https://safescoring.com
NODE_ENV=production

# ============================================================
# SUPABASE #1 - HOT DATA (Users, Setups, Payments)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# SUPABASE #2 - REFERENCE DATA (Products, Norms) [OPTIONAL]
# Create a second free Supabase project for more storage
# ============================================================
# SUPABASE_REF_URL=https://your-second-project.supabase.co
# SUPABASE_REF_ANON_KEY=your_ref_anon_key
# SUPABASE_REF_SERVICE_KEY=your_ref_service_key

# ============================================================
# TURSO - HISTORICAL DATA (9GB free) [OPTIONAL]
# Sign up at: https://turso.tech
# ============================================================
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_token

# ============================================================
# CLOUDFLARE R2 - FILES (10GB free) [OPTIONAL]
# ============================================================
# R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=safescoring-files

# ============================================================
# LEMON SQUEEZY (Fiat Payments - Credit Card)
# ============================================================
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Plan variant IDs
LEMON_SQUEEZY_EXPLORER_VARIANT_ID=123456
LEMON_SQUEEZY_PRO_VARIANT_ID=123457
LEMON_SQUEEZY_ENTERPRISE_VARIANT_ID=123458

# ============================================================
# NOWPAYMENTS (Crypto Payments - BTC/ETH/USDC)
# ============================================================
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_webhook_secret

# ============================================================
# NEXTAUTH (Authentication)
# ============================================================
NEXTAUTH_URL=https://safescoring.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars

# ============================================================
# OPTIONAL: OAuth Providers
# ============================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# ============================================================
# OPTIONAL: Email Provider (Resend/SendGrid)
# ============================================================
RESEND_API_KEY=your_resend_api_key
# or
SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================================
# OPTIONAL: Analytics
# ============================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=safescoring.com

# ============================================================
# AI PROVIDERS (for Incident Analysis & Evaluations)
# ============================================================
# Priority chain when Gemini exhausted:
# Groq -> SambaNova -> Together -> Cerebras -> Mistral -> DeepSeek -> Ollama

# ============================================================
# FREE TIER PROVIDERS (Recommended)
# ============================================================

# SambaNova (FREE - FASTEST: 200 tokens/sec! Llama 3.1 70B)
# Get free key at: https://sambanova.ai/fast-api
SAMBANOVA_API_KEY=your_sambanova_api_key

# Groq (FREE - 100k tokens/day per key, 5 keys = 500k/day)
# Get keys at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# GROQ_API_KEY_2=your_second_groq_key
# GROQ_API_KEY_3=your_third_groq_key

# Mistral AI (FREE - 1 billion tokens/month!)
# Get key at: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key

# Together AI (FREE $25 startup credits)
# Get key at: https://www.together.ai
TOGETHER_API_KEY=your_together_api_key

# Cerebras (FREE tier - fast inference)
# CEREBRAS_API_KEY=your_cerebras_api_key

# OpenRouter (30+ free models, $5 initial credits)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=x-ai/grok-3-mini-beta

# ============================================================
# PREMIUM PROVIDERS (Optional - Better Quality)
# ============================================================

# Google Gemini (primary AI - multi-key rotation)
# Get keys at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key
# GOOGLE_API_KEY_1=your_second_key
# GOOGLE_API_KEY_2=your_third_key

# DeepSeek (excellent quality - $0.14/1M tokens)
# DEEPSEEK_API_KEY=your_deepseek_api_key

# ============================================================
# OPTIONAL: Local AI (Ollama)
# ============================================================
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b

# ============================================================
# SECURITY - HARDCORE MODE
# ============================================================

# Encryption key for sensitive data (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Admin emails (comma-separated) - first email is super admin
ADMIN_EMAILS=admin@safescoring.io,support@safescoring.io

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://safescoring.io,https://www.safescoring.io

# Rate limiting (Redis required for production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# CSRF protection
CSRF_SECRET=your_csrf_secret_min_32_chars

# Session security
SESSION_SECRET=your_session_secret_min_32_chars
SESSION_MAX_AGE=86400

# IP whitelist for admin routes (optional, comma-separated)
# ADMIN_IP_WHITELIST=1.2.3.4,5.6.7.8

# Security headers
HSTS_MAX_AGE=63072000
CSP_REPORT_URI=/api/csp-report

# Webhook signature secrets
WEBHOOK_SIGNING_SECRET=your_webhook_secret

# Cloudflare Turnstile (Bot Protection)
# TURNSTILE_SITE_KEY=your_turnstile_site_key
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ============================================================
# PRIVACY & ANONYMIZATION
# ============================================================

# Salt for hashing wallet addresses (generate: openssl rand -hex 32)
WALLET_HASH_SALT=your_wallet_hash_salt_64_chars_hex

# Salt for hashing email addresses (generate: openssl rand -hex 32)
EMAIL_HASH_SALT=your_email_hash_salt_64_chars_hex

# ============================================================
# ZERO-TRUST SECURITY (MILITARY GRADE)
# ============================================================

# Request signing secret (generate: openssl rand -hex 32)
SIGNING_SECRET=your_signing_secret_64_chars_hex

# Sealed payload encryption key (generate: openssl rand -hex 32)
SEAL_KEY=your_seal_key_64_chars_hex

# Request signing for API calls
REQUEST_SIGNING_SECRET=your_request_signing_secret_64_chars

# ============================================================
# THREAT INTELLIGENCE (Optional)
# ============================================================

# AbuseIPDB API (https://www.abuseipdb.com/)
# ABUSEIPDB_API_KEY=your_abuseipdb_key

# IPQualityScore API (https://www.ipqualityscore.com/)
# IPQS_API_KEY=your_ipqs_key

# VirusTotal API (https://www.virustotal.com/)
# VIRUSTOTAL_API_KEY=your_virustotal_key

# MaxMind GeoIP (https://www.maxmind.com/)
# MAXMIND_LICENSE_KEY=your_maxmind_key

# ============================================================
# ALERTING (Optional)
# ============================================================

# Slack webhook for security alerts
# SLACK_SECURITY_WEBHOOK=https://hooks.slack.com/services/xxx

# PagerDuty for critical alerts
# PAGERDUTY_ROUTING_KEY=your_pagerduty_key

# Discord webhook for alerts
# DISCORD_SECURITY_WEBHOOK=https://discord.com/api/webhooks/xxx

# ============================================================
# DEVELOPMENT ONLY
# ============================================================
# Use sandbox endpoints for testing
# NOWPAYMENTS_API_URL=https://api-sandbox.nowpayments.io/v1
