# =============================================================================
# SAFESCORING - Environment Configuration Template
# =============================================================================
# Copy this file to config/.env and fill in your values:
#   cp config/.env.example config/.env
#
# NEVER commit real API keys to version control!
# =============================================================================

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get from: https://supabase.com > Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# AI PROVIDERS (at least one required for evaluations)
# =============================================================================
# Option 1: Use Claude Code CLI (recommended - no API key needed)
CLAUDE_CODE_ONLY=true

# Option 2: Free API providers (set CLAUDE_CODE_ONLY=false)
# Mistral - https://console.mistral.ai
# MISTRAL_API_KEY=your_key_here

# Google Gemini - https://aistudio.google.com
# GOOGLE_API_KEY=your_key_here

# Groq - https://console.groq.com
# GROQ_API_KEY=your_key_here

# Cerebras - https://cloud.cerebras.ai
# CEREBRAS_API_KEY=your_key_here

# SambaNova - https://cloud.sambanova.ai
# SAMBANOVA_API_KEY=your_key_here

# OpenRouter - https://openrouter.ai
# OPENROUTER_API_KEY=your_key_here

# DeepSeek - https://platform.deepseek.com
# DEEPSEEK_API_KEY=your_key_here

# =============================================================================
# FLASK ADMIN (Required for admin panel)
# =============================================================================
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_random_string

# Admin credentials
# Generate hash: python -c "import hashlib; print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_sha256_hash_here

# =============================================================================
# NEXTAUTH (Required for web frontend)
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_to_a_random_string

# =============================================================================
# OPTIONAL: Payments
# =============================================================================
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# =============================================================================
# OPTIONAL: Email
# =============================================================================
# RESEND_API_KEY=

# =============================================================================
# OPTIONAL: Rate Limiting (Required for production)
# =============================================================================
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
