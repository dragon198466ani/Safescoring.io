# =============================================================================
# SafeScoring .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
config/.env
web/.env.local
secrets/
*.pem
*.key
.admin_temp_password

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# PyInstaller
*.manifest
*.spec

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Node.js / Next.js
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.nuxt/
.cache/
*.tsbuildinfo
next-env.d.ts

# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Cache & Temp
# -----------------------------------------------------------------------------
cache/
.cache/
tmp/
temp/
*.tmp
*.temp
*.bak

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
*.bundle.js
*.bundle.js.map

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Documentation builds
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.orig

# Large data files (keep templates)
data/*.xlsx
data/*.csv
!data/*_template.*

# Archive (if you want to keep local archives private)
# _archive/

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
.vercel
.netlify
.serverless/

# -----------------------------------------------------------------------------
# Sensitive files specific to SafeScoring
# CRITICAL: These files contain real API keys - NEVER commit them
# -----------------------------------------------------------------------------
API_CONFIG_SECRET.json
GITHUB_SECRETS.txt
config/.env.txt
config/.env
web/.env
web/.env.local
web/.env.production
web/.env.staging

# Claude Code settings (may contain MCP tokens)
.claude/settings.local.json

# Any file with "secret" or "credential" in the name
*SECRET*
*secret*
*credential*
*CREDENTIAL*

# Private keys
*.pem
*.key
*.p12
*.pfx
0x*.txt

# Backup files that may contain secrets
evaluations_*_backup.json
norm_documents_backup_*.zip
paywall_norm_ids.json

# Supabase local
supabase/.branches
supabase/.temp
nul

# -----------------------------------------------------------------------------
# SafeScoring — Temp & Generated Files
# -----------------------------------------------------------------------------

# Temp files from evaluation/scraping sessions
temp_*
.~lock.*

# Excel data files at repo root (data sources — too large for git)
*.xlsx
*.xls

# Worker logs and data from parallel evaluation
worker_*.log
worker_*.json

# Build/test output files (CI debugging artifacts)
web/build_*.txt
web/test_*.txt
web/ci_*.txt
web/npm_*.txt
web/C*UsersalexaDesktop*
test-output.txt
ci_logs*

# Claude project context (auto-generated)
CLAUDE_PROJECT_CONTEXT.md
.claude/

# One-off scripts (local use only)
_*.py
!__init__.py
_*.js
_*.py.template

# Unicode-mangled temp files (Claude Code path artifacts)
C*tempnodes_test.json

# Data exports and batch files (too large / ephemeral)
data/*.json
data/*.sql
data/*.txt
data/*.md
data/eval_*
data/sql_batches/
!data/README.md

# Generated reports and PDFs
reports/
audit_reports/
comparatif_*.pdf

# Archived/fallback scripts
_archive/

# Norm documentation downloads
norm_docs/
norm_pdfs/
norm_full_dump.json

# Misc evaluation scripts at root
eval_*.py
fix_*.py
run_*.py
!run_parallel.py
select_*.py
set_*.py
apply_*.py
launch_workers.bat
products_to_evaluate.json
applicability_*.txt
claude_applicability_output.txt

# Script output/report files (debug artifacts, not source)
scripts/*_output.txt
scripts/*_report.txt
scripts/audit_*.txt
scripts/scope_report.txt
scripts/enrich_type_output.txt
scripts/verify_types_output.txt
