{
  "name": "@safescoring/sdk",
  "version": "1.0.0",
  "description": "Official SDK for SafeScoring API - Security ratings for crypto products",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "safescoring",
    "crypto",
    "security",
    "rating",
    "defi",
    "blockchain",
    "audit",
    "score"
  ],
  "author": "SafeScoring Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/safescoring/sdk.git"
  },
  "homepage": "https://safescoring.io",
  "bugs": {
    "url": "https://github.com/safescoring/sdk/issues"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
